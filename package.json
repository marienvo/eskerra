{
  "name": "notebox-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start -w @notebox/mobile",
    "mobile:android": "npm run android -w @notebox/mobile",
    "mobile:ios": "npm run ios -w @notebox/mobile",
    "desktop": "npm run desktop:dev -w @notebox/desktop",
    "desktop:build": "npm run desktop:build -w @notebox/desktop",
    "lint": "npm run lint -w @notebox/mobile && npm run lint -w @notebox/desktop",
    "test": "npm run test -w @notebox/core && npm run test -w @notebox/mobile && node --test scripts/bump-release-version-lib.test.mjs",
    "test:scripts": "node --test scripts/bump-release-version-lib.test.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
