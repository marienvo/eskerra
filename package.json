{
  "name": "eskerra-monorepo",
  "private": true,
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "apk-release": "npm run apk-release -w @eskerra/mobile",
    "mobile": "npm run start -w @eskerra/mobile",
    "mobile:android": "npm run android -w @eskerra/mobile",
    "mobile:ios": "npm run ios -w @eskerra/mobile",
    "desktop": "npm run desktop:dev -w @eskerra/desktop",
    "desktop:build": "npm run desktop:build -w @eskerra/desktop",
    "lint": "npm run lint -w @eskerra/mobile && npm run lint -w @eskerra/desktop",
    "test": "npm run test -w @eskerra/core && npm run test -w @eskerra/mobile && node --test scripts/bump-release-version-lib.test.mjs && node --test scripts/tauri-desktop-build.test.mjs",
    "test:scripts": "node --test scripts/bump-release-version-lib.test.mjs scripts/tauri-desktop-build.test.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
